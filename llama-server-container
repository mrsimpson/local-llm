#!/bin/bash
# Universal llama.cpp server launcher for containers
# Sources model config and executes llama-server

set -e

CONFIG_DIR="${XDG_CONFIG_HOME:=$HOME/.config}/llama-cpp"
MODEL_CONFIG="${1:-default}"
CONFIG_FILE="$CONFIG_DIR/${MODEL_CONFIG}.conf"

# Remove the first argument (model config name)
shift

# Check if config file exists
if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Config file not found: $CONFIG_FILE"
    echo "Available configs:"
    ls -1 "$CONFIG_DIR"/*.conf 2>/dev/null | xargs -n1 basename -s .conf || echo "No configs found"
    exit 1
fi

# Source the config file
source "$CONFIG_FILE"

# Verify model path exists
if [[ ! -f "$MODEL_PATH" ]]; then
    echo "Error: Model file not found: $MODEL_PATH"
    exit 1
fi

# Build the llama.cpp command
LLAMA_CMD=(
    "llama-server"
    "-m" "$MODEL_PATH"
    "-c" "$CONTEXT_SIZE"
    "-b" "$BATCH_SIZE"
    "-ub" "$UBATCH_SIZE"
    "-t" "$THREADS"
    "-ngl" "$GPU_LAYERS"
)

# Add flash attention if enabled
if [[ "$FLASH_ATTN" == "1" ]]; then
    LLAMA_CMD+=("--flash-attn" "on")
fi

# Add jinja support if enabled
if [[ "$JINJA" == "1" ]]; then
    LLAMA_CMD+=("--jinja")
fi

# Add any additional arguments passed to the script
LLAMA_CMD+=("$@")

echo "Starting llama.cpp server with: $MODEL_NAME"
echo "Config: $CONFIG_FILE"
echo "Model: $MODEL_PATH"
echo ""
echo "Command: ${LLAMA_CMD[*]}"
echo ""

# Execute llama-server
exec "${LLAMA_CMD[@]}"
